# Node modules - do not copy heavy dependency folders into the Docker build context
# node_modules

# Next / build outputs - these are produced during build inside the image
# and should not be sent in the build context
# .next
# dist
# out
# 
# Environment files - keep secrets out of the image build context
# env
# .env.*

# Logs and runtime artifacts
logs
logs/*
*.log
npm-debug.log
yarn-error.log

# Editor and OS files
.DS_Store
.vscode
.idea

# VCS and dockerignore itself
.git
.gitignore
.dockerignore

# Package manager lockfiles you don't use (safe to ignore if not used locally)
# pnpm-lock.yaml

# Test / coverage / temp files
coverage
tmp
*.tgz