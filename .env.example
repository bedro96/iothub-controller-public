# Database
# For MongoDB Atlas:
DATABASE_URL="mongodb+srv://"

# JWT Secret (generate a secure random string)
JWT_SECRET=""

# Internal Service Token (for bypassing rate limits from trusted services)
INTERNAL_SERVICE_TOKEN=""

# Environment
NODE_ENV="development"

# Enable or disable the IoT consumer (set to "true" to enable)
IOT_CONSUMER_ENABLED ="true"

# NextAuth URL (update with your actual domain in production)
NEXTAUTH_URL="http://localhost:3000"

# Enable secure cookies in production (only sent over HTTPS) - set to "true" in production
ENABLE_SECURE_COOKIES="false"

# Logging Level (error, warn, info, http, debug)
LOG_LEVEL="info"

IOT_CONNECTION_STRING=""
IOT_PRIMARY_KEY_DEVICE=""
IOT_SECONDARY_KEY_DEVICE=""
#API_BEARER_TOKEN="c8f1e3d6a9b2c4f7e8d1a3b5c6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5"
IOT_EVENTHUB_CONNECTION_STRING=""
IOT_EVENTHUB_CONSUMER_GROUP="$Default"

# Device Configuration Parameters
INITIAL_RETRY_TIMEOUT="30"
MAX_RETRY="10"
MESSAGE_INTERVAL_SECONDS="5"
HERD_READY="false"
